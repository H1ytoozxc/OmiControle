# =======================================================================
# Sequoia Platform — example environment file
#
# For local dev, prefer running `./scripts/dev-up.sh` which generates
# keys + per-service TOML configs under backend/config/ — you don't
# usually need this file for development.
#
# This .env is read by sequoia-config as a fallback when the TOML files
# aren't present. Copy to .env and fill in real values.
# NEVER commit .env to git.
# =======================================================================

# --- Runtime ---
RUST_LOG=info,sqlx=warn,h2=warn,hyper=warn
SEQUOIA_ENV=development                  # development | staging | production
SEQUOIA_REGION=local

# --- Postgres (primary OLTP) ---
DATABASE_URL=postgres://sequoia:sequoia@localhost:5432/sequoia
DATABASE_MAX_CONNECTIONS=32
DATABASE_MIN_CONNECTIONS=4
DATABASE_ACQUIRE_TIMEOUT_MS=5000

# --- Redis (cache + pubsub + streams + rate limit) ---
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=16

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=sequoia
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# =======================================================================
# API Gateway  (sequoia_config prefix = GATEWAY, nested fields use __)
# =======================================================================
GATEWAY_BIND=0.0.0.0:8080
GATEWAY_REQUEST_TIMEOUT_S=30

# CORS — explicit allowlist (no wildcards in production).
# Multiple origins comma-separated.
GATEWAY_CORS_ORIGINS=http://localhost:3000

# Shared HMAC key for WebSocket tickets. Must be base64url-encoded and
# ≥ 32 bytes. Same value must be set on the realtime-gateway.
# Generate with: openssl rand 32 | base64 | tr '/+' '_-' | tr -d '='
GATEWAY_WS_TICKET_HMAC_KEY_B64=
GATEWAY_WS_TICKET_TTL_S=60

# Token verification. Leave LOCAL_PUBLIC_KEY_PEM unset to use JWKS_URL.
# In v0.1 we recommend the local-key path to avoid JWKS publishing setup.
GATEWAY_AUTH__ISSUER=https://auth.sequoia.local
GATEWAY_AUTH__AUDIENCE=sequoia-platform
GATEWAY_AUTH__JWKS_URL=http://localhost:9081/.well-known/jwks.json
GATEWAY_AUTH__LOCAL_PUBLIC_KEY_PEM=file://backend/secrets/jwt_es256.pub

# Downstream gRPC services. Empty string → that group of routes returns 503.
GATEWAY_UPSTREAMS__AUTH=http://localhost:9081
GATEWAY_UPSTREAMS__DEVICE=http://localhost:9082
GATEWAY_UPSTREAMS__AI=http://localhost:9084
GATEWAY_UPSTREAMS__WORKFLOW=http://localhost:9085
GATEWAY_UPSTREAMS__NOTIFICATION=http://localhost:9088
GATEWAY_UPSTREAMS__PLUGIN=
GATEWAY_UPSTREAMS__COMMAND=
GATEWAY_UPSTREAMS__TELEMETRY=

GATEWAY_RATE_LIMIT__PER_IP_RPS=100
GATEWAY_RATE_LIMIT__PER_TENANT_RPS=1000
GATEWAY_RATE_LIMIT__BURST=200

# =======================================================================
# Auth Service  (env prefix = AUTH)
# Note: jwt.signing_keys is a Vec<> — easiest to configure via TOML, see
#       backend/config/auth-service.toml.
# =======================================================================
AUTH_BIND=0.0.0.0:9081

# =======================================================================
# Device Service  (env prefix = DEVICE)
# =======================================================================
DEVICE_GRPC_BIND=0.0.0.0:9082
DEVICE_ENROLLMENT_TTL_S=600
DEVICE_CHANNEL_CAPACITY=256

# Device JWT signing — separate trust domain from user tokens.
DEVICE_DEVICE_JWT__ISSUER=https://device.sequoia.local
DEVICE_DEVICE_JWT__AUDIENCE=sequoia-device-channel
DEVICE_DEVICE_JWT__KID=device-2026-05
DEVICE_DEVICE_JWT__PRIVATE_KEY_PEM=file://backend/secrets/device_jwt.key
DEVICE_DEVICE_JWT__PUBLIC_KEY_PEM=file://backend/secrets/device_jwt.pub
DEVICE_DEVICE_JWT__TTL_S=86400

# =======================================================================
# Realtime Gateway  (env prefix = REALTIME)
# =======================================================================
REALTIME_BIND=0.0.0.0:8083
REALTIME_WS_PATH=/ws
REALTIME_MAX_CONNECTIONS=200000
REALTIME_HEARTBEAT_INTERVAL_S=20
# Same HMAC key as GATEWAY_WS_TICKET_HMAC_KEY_B64.
REALTIME_WS_TICKET_HMAC_KEY_B64=

# =======================================================================
# AI Orchestrator
# =======================================================================
AI_BIND=0.0.0.0:9084
AI_DEFAULT_MODEL=claude-opus-4-7
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# =======================================================================
# Other services
# =======================================================================
WORKFLOW_BIND=0.0.0.0:9085
NOTIFY_BIND=0.0.0.0:9088
TELEMETRY_BIND=0.0.0.0:9089
PLUGIN_BIND=0.0.0.0:9086
EXEC_BIND=0.0.0.0:9087

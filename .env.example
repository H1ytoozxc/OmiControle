# ── Sequoia Platform — production environment template ────────────────────────
# Copy this file to .env and fill in all values marked <CHANGE_ME>.
# Never commit .env to version control.

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_USER=sequoia
POSTGRES_PASSWORD=<CHANGE_ME>
POSTGRES_DB=sequoia

# Full DSN used by backend services
DATABASE_URL=postgres://sequoia:<CHANGE_ME>@postgres:5432/sequoia

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=<CHANGE_ME>
REDIS_URL=redis://:$(REDIS_PASSWORD)@redis:6379/0

# ── JWT signing keys ──────────────────────────────────────────────────────────
# PKCS8 PEM (EC P-256). Generate:
#   openssl ecparam -name prime256v1 -genkey -noout -out ec.key
#   openssl pkcs8 -topk8 -nocrypt -in ec.key -out jwt.key
#   openssl ec -in ec.key -pubout -out jwt.pub
#
# Set paths to the mounted key files, OR embed the PEM directly:
#   JWT_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
JWT_PRIVATE_KEY_PATH=/run/secrets/jwt_es256.key
JWT_PUBLIC_KEY_PATH=/run/secrets/jwt_es256.pub

# ── API Gateway ───────────────────────────────────────────────────────────────
# CORS: comma-separated list of allowed origins (no trailing slash)
GATEWAY_CORS_ORIGINS=https://app.yourcompany.com
GATEWAY_PORT=8080

# HMAC secret shared between api-gateway and realtime-gateway for WS tickets.
# Generate: openssl rand -base64 32
WS_TICKET_HMAC_KEY_B64=<CHANGE_ME>

# ── Auth service ──────────────────────────────────────────────────────────────
# Public URL used in JWT iss claim — must match what clients validate
JWT_ISSUER=https://auth.yourcompany.com
JWT_AUDIENCE=sequoia-platform

# ── Realtime gateway ─────────────────────────────────────────────────────────
# Must match WS_TICKET_HMAC_KEY_B64 above
REALTIME_WS_TICKET_HMAC_KEY_B64=<CHANGE_ME>

# ── Frontend (baked into Next.js image at build time) ────────────────────────
# Must match the public URL of the api-gateway
NEXT_PUBLIC_API_URL=https://api.yourcompany.com
NEXT_PUBLIC_WS_URL=wss://realtime.yourcompany.com/ws

# ── Image registry (for docker-compose.prod.yml) ─────────────────────────────
REGISTRY=ghcr.io/your-org/sequoia
VERSION=latest

# ── Ports ─────────────────────────────────────────────────────────────────────
FRONTEND_PORT=3000

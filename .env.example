# =======================================================================
# Sequoia Platform — example environment file
# Copy to .env and fill in real values. NEVER commit .env to git.
# =======================================================================

# --- Runtime ---
RUST_LOG=info,sqlx=warn,h2=warn,hyper=warn
SEQUOIA_ENV=development                  # development | staging | production
SEQUOIA_REGION=local

# --- Postgres (primary OLTP) ---
DATABASE_URL=postgres://sequoia:sequoia@localhost:5432/sequoia
DATABASE_MAX_CONNECTIONS=32
DATABASE_MIN_CONNECTIONS=4
DATABASE_ACQUIRE_TIMEOUT_MS=5000

# --- Redis (cache + pubsub + streams + rate limit) ---
REDIS_URL=redis://localhost:6379/0
REDIS_POOL_SIZE=16

# --- OpenTelemetry ---
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAMESPACE=sequoia
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local
OTEL_METRIC_EXPORT_INTERVAL=10000

# --- API Gateway ---
GATEWAY_BIND=0.0.0.0:8080
GATEWAY_PUBLIC_URL=http://localhost:8080
GATEWAY_REQUEST_TIMEOUT_S=30

# --- Auth Service ---
AUTH_BIND=0.0.0.0:8081
AUTH_JWT_PRIVATE_KEY_PEM_PATH=./secrets/jwt_es256.key
AUTH_JWT_PUBLIC_KEY_PEM_PATH=./secrets/jwt_es256.pub
AUTH_JWT_ISSUER=https://auth.sequoia.local
AUTH_ACCESS_TOKEN_TTL_S=900              # 15 min
AUTH_REFRESH_TOKEN_TTL_S=2592000         # 30 days
AUTH_DEVICE_TOKEN_TTL_S=3600             # 1 hour
AUTH_OIDC_PROVIDERS=google,github        # optional list

# OIDC provider config (per-provider)
OIDC_GOOGLE_CLIENT_ID=
OIDC_GOOGLE_CLIENT_SECRET=
OIDC_GOOGLE_ISSUER=https://accounts.google.com
OIDC_GOOGLE_REDIRECT_URI=http://localhost:8080/auth/oidc/google/callback

# --- Device Service ---
DEVICE_BIND=0.0.0.0:8082
DEVICE_GRPC_BIND=0.0.0.0:9082
DEVICE_ENROLLMENT_CODE_TTL_S=600

# --- Realtime Gateway ---
REALTIME_BIND=0.0.0.0:8083
REALTIME_WS_PATH=/ws
REALTIME_MAX_CONNECTIONS=200000
REALTIME_HEARTBEAT_INTERVAL_S=20

# --- AI Orchestrator ---
AI_BIND=0.0.0.0:8084
AI_DEFAULT_MODEL=claude-opus-4-7
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# --- Workflow Engine ---
WORKFLOW_BIND=0.0.0.0:8085
WORKFLOW_WORKER_CONCURRENCY=64

# --- Plugin Host ---
PLUGIN_BIND=0.0.0.0:8086
PLUGIN_WASM_DIR=./plugins
PLUGIN_FUEL_LIMIT=10000000
PLUGIN_MEMORY_PAGES_LIMIT=64

# --- Command Executor ---
EXEC_BIND=0.0.0.0:8087

# --- Notification Service ---
NOTIFY_BIND=0.0.0.0:8088
SMTP_URL=smtps://user:pass@smtp.example.com:465
FCM_SERVICE_ACCOUNT_JSON_PATH=

# --- Telemetry Service ---
TELEMETRY_BIND=0.0.0.0:8089
TELEMETRY_RETENTION_DAYS=30

# --- Cross-service auth (mTLS / internal token) ---
INTERNAL_SHARED_SECRET=change-me-to-32-byte-random-base64
INTERNAL_TLS_CA_PATH=./secrets/ca.pem
INTERNAL_TLS_CERT_PATH=./secrets/internal.crt
INTERNAL_TLS_KEY_PATH=./secrets/internal.key
